rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net: Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // 2. Verified individual database namespace
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidPreferences(incoming());
      allow update: if isOwner(userId) && isValidPreferences(incoming()) && isImmutableFieldsPreserved();
      allow delete: if isOwner(userId);
    }
    
    // Primitive global authorization helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // Validates structured preferences map values for size, presence, and types
    function isValidPreferences(data) {
      return data.uid is string
          && data.uid.size() <= 128
          && data.email is string
          && data.email.size() <= 200
          && data.savedCities is list
          && data.savedCities.size() <= 30
          && data.unitSystem is string
          && data.unitSystem in ['metric', 'imperial']
          && data.gridConfig is map
          && data.updatedAt is number;
    }
    
    // Ensure vital account bindings cannot be spoofed or transferred post-creation
    function isImmutableFieldsPreserved() {
      return incoming().uid == existing().uid
          && incoming().email == existing().email;
    }
  }
}
